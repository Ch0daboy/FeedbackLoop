// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials login
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  feedback  Feedback[]
  projects  Project[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  ADMIN
  DEVELOPER
}

// Core SaaS models
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  githubRepo  String   // GitHub repository URL
  githubToken String?  // Encrypted GitHub token for this project
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  feedback Feedback[]

  @@index([ownerId])
}

model Feedback {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  email       String?        // Optional email from anonymous users
  category    String?        // Will be set by AI analysis
  priority    Priority?      // Will be set by AI analysis
  sentiment   Sentiment?     // Will be set by AI analysis
  status      FeedbackStatus @default(PENDING)
  projectId   String
  userId      String?        // Optional - for authenticated users
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  analysis        FeedbackAnalysis?
  implementation  Implementation?

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@unique([title, projectId])
}

model FeedbackAnalysis {
  id                String   @id @default(cuid())
  feedbackId        String   @unique
  geminiResponse    String   @db.Text // Raw response from Gemini
  extractedCategory String?
  extractedPriority Priority?
  extractedSentiment Sentiment?
  isImplementable   Boolean  @default(false)
  implementationSuggestion String? @db.Text
  createdAt         DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model Implementation {
  id              String              @id @default(cuid())
  feedbackId      String              @unique
  githubBranch    String              // Branch name created for this implementation
  claudeResponse  String              @db.Text // Raw response from Claude
  generatedCode   String              @db.Text // Code generated by Claude
  status          ImplementationStatus @default(PENDING)
  githubPrUrl     String?             // URL to the created PR
  errorMessage    String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Enums
enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FeedbackStatus {
  PENDING
  ANALYZING
  ANALYZED
  IMPLEMENTING
  IMPLEMENTED
  REJECTED
}

enum ImplementationStatus {
  PENDING
  GENERATING_CODE
  CREATING_BRANCH
  COMMITTING_CODE
  CREATING_PR
  COMPLETED
  FAILED
}
